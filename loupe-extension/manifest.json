{
  "manifest_version": 3,
  "name": "Loupe",
  "version": "2.4",
  "description": "Extract live styles and send to Loupe for Figma comparison",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Loupe — Extract & Compare",
    "default_popup": "popup.html"
  }
}
